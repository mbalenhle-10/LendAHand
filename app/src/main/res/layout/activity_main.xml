<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F6F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- HANDSHAKE ICON -->
        <TextView
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:gravity="center"
            android:text="🤝"
            android:textSize="34sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/icon_bg"
            android:layout_marginTop="55dp" />

        <!-- APP NAME -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GiveLocal"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#2F3E46"
            android:layout_marginTop="18dp" />

        <!-- TAGLINE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Share what you have. Receive what you need."
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="35dp" />

        <!-- CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="22dp"
            android:elevation="6dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome back 👋"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2F3E46" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Log in to continue helping your community."
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="22dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EMAIL ADDRESS"
                android:textColor="#6B7280"
                android:textStyle="bold"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Email address"
                android:inputType="textEmailAddress"
                android:padding="14dp"
                android:textSize="14sp"
                android:background="@android:drawable/edit_text"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textColor="#6B7280"
                android:textStyle="bold"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Enter password"
                android:inputType="textPassword"
                android:padding="14dp"
                android:textSize="14sp"
                android:background="@android:drawable/edit_text"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Forgot password?"
                android:textColor="#2F3E46"
                android:textStyle="bold"
                android:textSize="13sp"
                android:gravity="end"
                android:layout_marginBottom="22dp" />

            <Button
                android:id="@+id/signInButton"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Sign in"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2F3E46" />

            <TextView
                android:id="@+id/createAccountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New here? Create account"
                android:textColor="#2F3E46"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>